{
  "name": "la3-language",
  "displayName": "La3 (Laila Lang)",
  "description": "Syntax highlighting, live diagnostics, and run/build commands for Laila Lang (La3).",
  "version": "0.2.2",
  "icon": "images/icon.png",
  "publisher": "glazastov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/glazastov/la3"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "bundle:bin": "cargo build --release --manifest-path ../../Cargo.toml && node scripts/bundle-binary.mjs",
    "vscode:prepublish": "tsc -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.4.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "la3",
        "aliases": [
          "La3",
          "Laila Lang",
          "la3"
        ],
        "extensions": [
          ".la3"
        ],
        "icon": {
          "light": "./images/la3-file.png",
          "dark": "./images/la3-file.png"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "la3",
        "scopeName": "source.la3",
        "path": "./syntaxes/la3.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "la3.check",
        "title": "La3: Check current file",
        "category": "La3"
      },
      {
        "command": "la3.run",
        "title": "La3: Run current file",
        "category": "La3"
      },
      {
        "command": "la3.build",
        "title": "La3: Build interpreter (cargo build --release)",
        "category": "La3"
      }
    ],
    "configuration": {
      "title": "La3",
      "properties": {
        "la3.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to the `la3` binary. When empty, the extension looks for `target/release/la3` then `target/debug/la3` under the workspace, and finally `la3` on your `PATH`."
        },
        "la3.diagnostics.run": {
          "type": "string",
          "enum": [
            "onType",
            "onSave",
            "off"
          ],
          "default": "onType",
          "enumDescriptions": [
            "Re-check the file as you type (debounced).",
            "Re-check only when the file is saved.",
            "Disable live diagnostics."
          ],
          "description": "When to run `la3 check` for diagnostics."
        },
        "la3.diagnostics.debounce": {
          "type": "number",
          "default": 350,
          "description": "Milliseconds to wait after the last keystroke before re-checking (onType mode)."
        }
      }
    }
  }
}
